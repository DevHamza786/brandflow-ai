# API base (use /api/v1 with Vite proxy in dev)
VITE_API_BASE_URL=/api/v1

# Proxy target for vite.config.ts (dev only)
VITE_API_PROXY_TARGET=http://localhost:8080

# Default workspace for MVP (auth will replace this)
VITE_DEFAULT_WORKSPACE_ID=9bb59c64-347a-48b3-b010-e41b5cdc6f4d

# Default content version for hook generation demo
VITE_DEFAULT_CONTENT_VERSION_ID=52686c43-b35d-4d23-a271-562d14632d02

# Polling interval while workflow is in-flight (ms)
VITE_POLL_INTERVAL_MS=2500
