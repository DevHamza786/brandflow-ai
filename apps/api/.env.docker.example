# =============================================================================
# PBOS Laravel API — Docker development environment
# Copy to .env:  cp .env.docker.example .env
# =============================================================================

APP_NAME="PBOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- PostgreSQL (service: postgres) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pbos
DB_USERNAME=pbos
DB_PASSWORD=pbos_secret

# --- Redis (service: redis) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache, session, queue — all Redis per architecture
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# Horizon uses same Redis connection
REDIS_QUEUE_CONNECTION=default

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

# --- AI providers (set your keys) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=gemini
AI_ENABLE_FALLBACK=true
AI_USE_NULL_GATEWAY=false
OPENAI_DEFAULT_MODEL=gpt-4o-mini
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# --- PBOS ---
PBOS_EMBEDDING_DIMENSIONS=1536
WORKFLOW_STATE_TTL=604800
# Must match apps/web .env VITE_DEFAULT_WORKSPACE_ID for local SPA + OAuth
PBOS_DEV_WORKSPACE_ID=9bb59c64-347a-48b3-b010-e41b5cdc6f4d

# --- LinkedIn OAuth (https://www.linkedin.com/developers/) ---
# Products: enable "Sign In with LinkedIn (OpenID)" + "Share on LinkedIn" on the app.
# - OpenID only: LINKEDIN_SCOPES=openid,profile,email
# - With Share on LinkedIn product enabled, add posting scope:
LINKEDIN_SCOPES=openid,profile,email,w_member_social
FRONTEND_URL=http://localhost:5173
INTEGRATIONS_SUCCESS_REDIRECT="${FRONTEND_URL}/settings/integrations?linkedin=connected"
INTEGRATIONS_ERROR_REDIRECT="${FRONTEND_URL}/settings/integrations?linkedin=error"
INTEGRATIONS_OAUTH_STATE_TTL=600
INTEGRATIONS_TOKEN_REFRESH_LEAD=3600

# LinkedIn REST (UGC) — version header on post requests (OAuth block above stays the source of scopes/tokens)
LINKEDIN_API_BASE=https://api.linkedin.com
LINKEDIN_UGC_PATH=/v2/ugcPosts
LINKEDIN_API_VERSION=202404

# --- Docker entrypoint ---
RUN_MIGRATIONS=true
RUN_PGVECTOR_MIGRATIONS=true
# Create workspaces row for the UUID used by the web app (see PBOS_DEV_WORKSPACE_ID)
SEED_DEV_DEFAULT_WORKSPACE=true
# Auto-create missing workspaces row in local (fixes LinkedIn FK if seed did not run)
PBOS_AUTO_BOOTSTRAP_LOCAL_WORKSPACE=true

VITE_APP_NAME="${APP_NAME}"
