# =============================================================================
# PBOS Docker Compose — root environment (variable substitution)
# Copy to .env:  cp .env.docker.example .env
# =============================================================================

# --- Application URLs ---
NGINX_PORT=8080
APP_URL=http://localhost:8080

# --- PostgreSQL ---
POSTGRES_DB=pbos
POSTGRES_USER=pbos
POSTGRES_PASSWORD=pbos_secret
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Laravel bootstrap (api / horizon / scheduler) ---
RUN_MIGRATIONS=true
RUN_PGVECTOR_MIGRATIONS=true

# --- Optional: pgAdmin (profile: tools) ---
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@pbos.local
PGADMIN_PASSWORD=pbos_admin

# --- Docker build ---
UID=1000
GID=1000
